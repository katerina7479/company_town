#!/bin/sh
# Company Town pre-commit hook: block commits that contain unformatted Go code.
#
# Install with: make install-hooks
#
# Checks only the files actually staged for commit, so it's fast and only
# complains about what this commit is changing.

set -e

staged_go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$staged_go_files" ]; then
    exit 0
fi

unformatted=$(echo "$staged_go_files" | xargs gofmt -l 2>/dev/null || true)

if [ -n "$unformatted" ]; then
    echo "pre-commit: the following staged Go files are not gofmt-clean:" >&2
    echo "$unformatted" | sed 's/^/  /' >&2
    echo >&2
    echo "Run: gofmt -w $(echo $unformatted | tr '\n' ' ')" >&2
    echo "Then: git add <files> && git commit" >&2
    exit 1
fi
